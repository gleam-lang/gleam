type Container {
  Container(inner: Wibble)
}

type Wibble {
  Wibble(wibble: Int, wobble: Int)
                      ↑▔▔▔▔▔      
}

pub fn main(c: Container) {
  Wibble(..c.inner, wibble: 2)
}
