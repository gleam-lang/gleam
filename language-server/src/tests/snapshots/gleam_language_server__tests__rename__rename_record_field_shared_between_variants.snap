pub type Shape {
  Square(colour: Int, width: Int)
         ↑▔▔▔▔▔                  
  Circle(colour: Int, radius: Int)
}

pub fn main() {
  let shape = Square(colour: 1, width: 10)
  case shape {
    Circle(colour:, ..) -> colour
    Square(..) -> shape.colour
  }
}


----- AFTER RENAME
-- app.gleam

pub type Shape {
  Square(shade: Int, width: Int)
  Circle(shade: Int, radius: Int)
}

pub fn main() {
  let shape = Square(shade: 1, width: 10)
  case shape {
    Circle(shade: colour, ..) -> colour
    Square(..) -> shape.shade
  }
}
