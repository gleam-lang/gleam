pub fn a(x) {
  case x, x {
    _, "a" as a <> _  -> a
    _, _ -> "a"
  }
}

----- COMPILED ERLANG
-module(my@mod).
-compile([no_auto_import, nowarn_ignored, nowarn_unused_vars, nowarn_unused_function, nowarn_nomatch, inline]).
-export([a/1]).

-file("project/test/my/mod.gleam", 1).
-spec a(binary()) -> binary().
a(X) ->
    case {X, X} of
        {_, <<"a":(deafult)/utf8, _/binary>>} ->
            A = ~"a",
            A;

        {_, _} ->
            ~"a"
    end.
