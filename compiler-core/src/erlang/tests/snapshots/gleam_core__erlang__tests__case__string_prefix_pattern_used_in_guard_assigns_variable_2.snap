----- SOURCE CODE

pub fn go(x) {
  case x {
    "a" as letter <> rest
    | "b" as rest <> letter if letter == "c" && rest == "b" -> letter <> rest
    _ -> ""
  }
}


----- COMPILED ERLANG
-module(my@mod).
-compile([no_auto_import, nowarn_ignored, nowarn_unused_vars, nowarn_unused_function, nowarn_nomatch, inline]).
-export([go/1]).

-file("project/test/my/mod.gleam", 2).
-spec go(binary()) -> binary().
go(X) ->
    case X of
        <<"a"/utf8, Rest/binary>> when (<<"a"/utf8>> =:= <<"c"/utf8>>) andalso (Rest =:= <<"b"/utf8>>) ->
            Letter = <<"a"/utf8>>,
            <<Letter/binary, Rest/binary>>;

        <<"b"/utf8, Letter/binary>> when (Letter =:= <<"c"/utf8>>) andalso (<<"b"/utf8>> =:= <<"b"/utf8>>) ->
            Rest = <<"b"/utf8>>,
            <<Letter/binary, Rest/binary>>;

        _ ->
            <<""/utf8>>
    end.
