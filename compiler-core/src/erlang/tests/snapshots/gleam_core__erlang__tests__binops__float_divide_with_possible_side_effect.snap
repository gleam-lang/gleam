----- SOURCE CODE
pub fn main(a, b) { a() /. b }

----- COMPILED ERLANG
-module(my@mod).
-compile([no_auto_import, nowarn_ignored, nowarn_unused_vars, nowarn_unused_function, nowarn_nomatch, inline]).
-export([main/2]).

-file("project/test/my/mod.gleam", 1).
-spec main(fun(() -> float()), float()) -> float().
main(A, B) ->
    _value = A(),
    case B of
        +0.0 ->
            +0.0;

        -0.0 ->
            -0.0;

        _value@1 ->
            _value / _value@1
    end.
