----- SOURCE CODE

pub fn main(x) {
  case x {
    <<_ as b>> if b == 1 -> b + 2
    _ -> 0
  }
}

----- COMPILED ERLANG
-module(my@mod).
-compile([no_auto_import, nowarn_ignored, nowarn_unused_vars, nowarn_unused_function, nowarn_nomatch, inline]).
-export([main/1]).

-file("project/test/my/mod.gleam", 2).
-spec main(bitstring()) -> integer().
main(X) ->
    case X of
        <<B>> when B =:= 1 ->
            B + 2;

        _ ->
            0
    end.
