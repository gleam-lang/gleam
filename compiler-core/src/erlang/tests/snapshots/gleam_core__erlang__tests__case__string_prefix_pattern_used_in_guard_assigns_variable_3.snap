----- SOURCE CODE

pub fn go(x) {
  case x {
    "a" as rest <> _
    | "b" <> rest if rest == "c" -> Nil
    _ -> Nil
  }
}


----- COMPILED ERLANG
-module(my@mod).
-compile([no_auto_import, nowarn_ignored, nowarn_unused_vars, nowarn_unused_function, nowarn_nomatch, inline]).
-export([go/1]).

-file("project/test/my/mod.gleam", 2).
-spec go(binary()) -> nil.
go(X) ->
    case X of
        <<"a"/utf8, _/binary>> when <<"a"/utf8>> =:= <<"c"/utf8>> ->
            Rest = <<"a"/utf8>>,
            nil;

        <<"b"/utf8, Rest/binary>> when Rest =:= <<"c"/utf8>> ->
            nil;

        _ ->
            nil
    end.
