----- SOURCE CODE

pub fn go(x) {
  case x {
    "a" as letter <> rest
    | "b" as rest <> letter if letter == "c" && rest == "b" -> letter <> rest
    _ -> ""
  }
}


----- COMPILED ERLANG
-module(my@mod).
-compile([no_auto_import, nowarn_ignored, nowarn_unused_vars, nowarn_unused_function, nowarn_nomatch, inline]).
-export([go/1]).

-file("project/test/my/mod.gleam", 2).
-spec go(binary()) -> binary().
go(X) ->
    case X of
        <<"a":(deafult)/utf8, Rest/binary>> when (~"a" =:= ~"c") andalso (Rest =:= ~"b") ->
            Letter = ~"a",
            <<Letter/binary, Rest/binary>>;

        <<"b":(deafult)/utf8, Letter/binary>> when (Letter =:= ~"c") andalso (~"b" =:= ~"b") ->
            Rest = ~"b",
            <<Letter/binary, Rest/binary>>;

        _ ->
            ~""
    end.
