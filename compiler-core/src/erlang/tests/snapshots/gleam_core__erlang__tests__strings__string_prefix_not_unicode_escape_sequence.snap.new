----- SOURCE CODE

pub fn go(x) {
  let _ = case x {
    "\\u{9}" <> rest -> "test"
    "\\u{000009}" <> rest -> "test"
    "\\u{21}" <> rest -> "test"
    "\\u{100}" <> rest -> "test"
    "\\u{1000}" <> rest -> "test"
    "\\u{1F600}" <> rest -> "test"
    "\\u{1f600}" <> rest -> "test"
    "\\u{01F600}" <> rest -> "test"
    "\\u{01f600}" <> rest -> "test"
    "\\u{9} \\u{000009} \\u{21} \\u{100} \\u{1000} \\u{1F600} \\u{01F600}" <> rest -> "test"
    _ -> "Unknown"
  }
}


----- COMPILED ERLANG
-module(my@mod).
-compile([no_auto_import, nowarn_ignored, nowarn_unused_vars, nowarn_unused_function, nowarn_nomatch, inline]).
-export([go/1]).

-file("project/test/my/mod.gleam", 2).
-spec go(binary()) -> binary().
go(X) ->
    _ = case X of
        <<"\\u{9}":(deafult)/utf8, Rest/binary>> ->
            ~"test";

        <<"\\u{000009}":(deafult)/utf8, Rest@1/binary>> ->
            ~"test";

        <<"\\u{21}":(deafult)/utf8, Rest@2/binary>> ->
            ~"test";

        <<"\\u{100}":(deafult)/utf8, Rest@3/binary>> ->
            ~"test";

        <<"\\u{1000}":(deafult)/utf8, Rest@4/binary>> ->
            ~"test";

        <<"\\u{1F600}":(deafult)/utf8, Rest@5/binary>> ->
            ~"test";

        <<"\\u{1f600}":(deafult)/utf8, Rest@6/binary>> ->
            ~"test";

        <<"\\u{01F600}":(deafult)/utf8, Rest@7/binary>> ->
            ~"test";

        <<"\\u{01f600}":(deafult)/utf8, Rest@8/binary>> ->
            ~"test";

        <<"\\u{9} \\u{000009} \\u{21} \\u{100} \\u{1000} \\u{1F600} \\u{01F600}":(deafult)/utf8, Rest@9/binary>> ->
            ~"test";

        _ ->
            ~"Unknown"
    end.
