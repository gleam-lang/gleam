----- SOURCE CODE

pub fn go(x) {
  case x {
    ["a" as letter <> rest, ..]
    | ["b" as letter <> rest, ..] -> letter <> rest
    _ -> ""
  }
}


----- COMPILED ERLANG
-module(my@mod).
-compile([no_auto_import, nowarn_ignored, nowarn_unused_vars, nowarn_unused_function, nowarn_nomatch, inline]).
-export([go/1]).

-file("project/test/my/mod.gleam", 2).
-spec go(list(binary())) -> binary().
go(X) ->
    case X of
        [<<"a"/utf8, Rest/binary>> | _] ->
            Letter = <<"a"/utf8>>,
            <<Letter/binary, Rest/binary>>;

        [<<"b"/utf8, Rest/binary>> | _] ->
            Letter = <<"b"/utf8>>,
            <<Letter/binary, Rest/binary>>;

        _ ->
            <<""/utf8>>
    end.
