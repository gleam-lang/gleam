----- SOURCE CODE

pub fn go(x) {
  case x {
    1 | 2 -> {
      let a = 1
      Nil
    }
    3 -> {
      let a = 2
      Nil
    }
    _ -> Nil
  }

  let a = 4
  a + 1
}


----- COMPILED ERLANG
-module(my@mod).
-compile([no_auto_import, nowarn_ignored, nowarn_unused_vars, nowarn_unused_function, nowarn_nomatch, inline]).
-export([go/1]).

-file("project/test/my/mod.gleam", 2).
-spec go(integer()) -> integer().
go(X) ->
    case X of
        1 ->
            A = 1,
            nil;

        2 ->
            A = 1,
            nil;

        3 ->
            A@1 = 2,
            nil;

        _ ->
            nil
    end,
    A@2 = 4,
    A@2 + 1.
