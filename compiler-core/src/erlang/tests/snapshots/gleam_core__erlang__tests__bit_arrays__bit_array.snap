    A = 1,
    Simple = <<1, A>>,
    Complex = <<4/integer-big, 5.0/little-float, 6/native-integer>>,
    case <<1>> of
        <<7:2, 8:3, B:4/binary>> ->
            case <<1>> of
                <<C:8/unit:1, D:2/binary-unit:2>> ->
