----- SOURCE CODE

pub fn go(bits) {
  case bits {
    <<_:16, _:32, _:bytes>> -> 1
    <<_:24, _:16, _:bytes>> -> 1
    <<_:8, _:8, _:8, _:bytes>> -> 1
    <<_:bytes>> -> 1
    _ -> 0
  }
}


----- COMPILED JAVASCRIPT
export function go(bits) {
  if (bits.bitSize >= 16) {
    if (bits.bitSize >= 48) {
      if ((bits.bitSize - 48) % 8 === 0) {
        return 1;
      } else if ((bits.bitSize - 40) % 8 === 0) {
        return 1;
      } else if ((bits.bitSize - 24) % 8 === 0) {
        return 1;
      } else if (bits.bitSize % 8 === 0) {
        return 1;
      } else {
        return 0;
      }
    } else if (bits.bitSize >= 24) {
      if (bits.bitSize >= 40 && (bits.bitSize - 40) % 8 === 0) {
        return 1;
      } else if ((bits.bitSize - 24) % 8 === 0) {
        return 1;
      } else if (bits.bitSize % 8 === 0) {
        return 1;
      } else {
        return 0;
      }
    } else if (bits.bitSize % 8 === 0) {
      return 1;
    } else {
      return 0;
    }
  } else if (bits.bitSize % 8 === 0) {
    return 1;
  } else {
    return 0;
  }
}
