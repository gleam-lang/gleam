const some_size = 2

pub fn run(data) {
  case data {
    <<x:bytes-size(some_size), _:bits>> -> x
    _ -> data
  }
}
        

----- COMPILED JAVASCRIPT
import { bitArraySlice } from "../gleam.mjs";

const some_size = 2;

export function run(data) {
  if (some_size * 8 >= 0 && data.bitSize >= some_size * 8) {
    let x = bitArraySlice(data, 0, some_size * 8);
    return x;
  } else {
    return data;
  }
}
