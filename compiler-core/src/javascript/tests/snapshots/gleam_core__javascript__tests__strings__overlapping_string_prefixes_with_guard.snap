----- SOURCE CODE

pub fn classify(input: String, flag: Bool) -> String {
  case input {
    "aa" <> _rest if flag -> "wibble"
    "a" <> _rest if flag -> "wobble"
    "a" <> _rest -> "woo"
    _ -> "other"
  }
}


----- COMPILED JAVASCRIPT
export function classify(input, flag) {
  if (input.startsWith("aa") && flag) {
    return "wibble";
  } else if (input.charCodeAt(0) === 97) {
    if (flag) {
      return "wobble";
    } else {
      return "woo";
    }
  } else {
    return "other";
  }
}
