----- COMPILED JAVASCRIPT
import { makeError, toBitArray } from "../gleam.mjs";

const FILEPATH = "src/module.gleam";

export function main() {
  let a = 2;
  let b = 3;
  let c = 4;
  let $ = toBitArray([]);
  if (!(((a * b) * c) * 8 >= 0 && $.bitSize === ((a * b) * c) * 8)) {
    throw makeError(
      "let_assert",
      FILEPATH,
      "my/mod",
      6,
      "main",
      "Pattern match failed, no pattern matched the value.",
      { value: $, start: 55, end: 100, pattern_start: 66, pattern_end: 93 }
    )
  }
  return $;
}
