----- COMPILED JAVASCRIPT
import { makeError, bitArraySliceToInt } from "../gleam.mjs";
import * as $sizes from "../sizes.mjs";

const FILEPATH = "src/module.gleam";

const local_size = 4;

export function go(data) {
  let value;
  if (
    $sizes.multiplier * local_size >= 0 &&
    data.bitSize === $sizes.multiplier * local_size
  ) {
    value = bitArraySliceToInt(data, 0, $sizes.multiplier * local_size, true, false);
  } else {
    throw makeError(
      "let_assert",
      FILEPATH,
      "my/mod",
      7,
      "go",
      "Pattern match failed, no pattern matched the value.",
      { value: data, start: 57, end: 120, pattern_start: 68, pattern_end: 113 }
    )
  }
  return value;
}
