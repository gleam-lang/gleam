----- SOURCE CODE

pub fn go(x) {
  let n = 1
  case x {
    <<_:size(n), _, _:bytes>> -> 1
    _ -> 2
  }
}


----- COMPILED JAVASCRIPT
export function go(x) {
  let n = 1;
  if (
    n >= 0 &&
    x.bitSize >= n &&
    x.bitSize >= 8 + n &&
    (x.bitSize - n) % 8 === 0
  ) {
    return 1;
  } else {
    return 2;
  }
}
