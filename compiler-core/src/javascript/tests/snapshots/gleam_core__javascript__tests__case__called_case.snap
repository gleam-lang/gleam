pub fn go(x, y) {
  case x {
    0 -> y
    _ -> y
  }()
}


----- COMPILED JAVASCRIPT
export function go(x, y) {
  let _block;
  if (x === 0) {
    _block = y;
  } else {
    _block = y;
  }
  return _block();
}
