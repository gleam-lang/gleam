pub fn go(x) {
  case x {
    <<_:float-32>> -> "float"
    _ -> "other"
  }
}


----- COMPILED JAVASCRIPT
import { bitArraySliceToFloat } from "../gleam.mjs";

export function go(x) {
  if (x.bitSize === 32) {
    let $;
    if (Number.isFinite($ = bitArraySliceToFloat(x, 0, 32, true))) {
      return "float";
    } else {
      return "other";
    }
  } else {
    return "other";
  }
}
