----- SOURCE CODE

import gleam

pub fn go(x) {
   case x {
     "a" <> rest -> "a" <> rest
     _ -> ""
   }
}

----- COMPILED JAVASCRIPT
import * as $gleam from "../gleam.mjs";

export function go(x) {
  if (x.charCodeAt(0) === 97) {
    return x;
  } else {
    return "";
  }
}
