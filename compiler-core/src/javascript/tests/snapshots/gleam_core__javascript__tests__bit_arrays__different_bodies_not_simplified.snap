----- SOURCE CODE

pub fn go(bits) {
  case bits {
    <<_:16, _:bytes>> -> 1
    <<_:bytes>> -> 2
    _ -> 0
  }
}


----- COMPILED JAVASCRIPT
export function go(bits) {
  if (bits.bitSize >= 16) {
    if (bits.bitSize % 8 === 0) {
      return 1;
    } else {
      return 0;
    }
  } else if (bits.bitSize % 8 === 0) {
    return 2;
  } else {
    return 0;
  }
}
