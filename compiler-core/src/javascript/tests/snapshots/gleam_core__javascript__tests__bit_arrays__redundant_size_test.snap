----- SOURCE CODE

pub fn go(bits) {
  case bits {
    <<_:16, _:bytes>> |
    <<_:bytes>> -> 1
    _ -> 0
  }
}


----- COMPILED JAVASCRIPT
export function go(bits) {
  if (bits.bitSize % 8 === 0) {
    return 1;
  } else {
    return 0;
  }
}
