pub fn go(x) {
  case <<1, 2, 3>> {
    <<_, b:bytes>> -> b
    _ -> x
  }
}


----- COMPILED JAVASCRIPT
import { toBitArray, bitArraySlice } from "../gleam.mjs";

export function go(x) {
  let $ = toBitArray([1, 2, 3]);
  if ($.bitSize >= 8 && ($.bitSize - 8) % 8 === 0) {
    let b = bitArraySlice($, 8);
    return b;
  } else {
    return x;
  }
}
