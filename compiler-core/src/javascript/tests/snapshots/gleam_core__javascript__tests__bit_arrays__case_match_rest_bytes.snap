----- SOURCE CODE

pub fn go(x) {
  case x {
    <<_, b:bytes>> -> b
    _ -> x
  }
}


----- COMPILED JAVASCRIPT
import { bitArraySlice } from "../gleam.mjs";

export function go(x) {
  if (x.bitSize >= 8 && (x.bitSize - 8) % 8 === 0) {
    let b = bitArraySlice(x, 8);
    return b;
  } else {
    return x;
  }
}
