----- COMPILED JAVASCRIPT
import { makeError, divideInt, toBitArray } from "../gleam.mjs";

const FILEPATH = "src/module.gleam";

export function main() {
  let a = 100;
  let b = 5;
  let c = 2;
  let $ = toBitArray([]);
  if (!(
    (divideInt((divideInt(a, b)), c)) * 8 >= 0 &&
    $.bitSize === (divideInt((divideInt(a, b)), c)) * 8
  )) {
    throw makeError(
      "let_assert",
      FILEPATH,
      "my/mod",
      6,
      "main",
      "Pattern match failed, no pattern matched the value.",
      { value: $, start: 57, end: 102, pattern_start: 68, pattern_end: 95 }
    )
  }
  return $;
}
