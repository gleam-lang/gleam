----- COMPILED JAVASCRIPT
import { makeError, bitArraySliceToInt } from "../gleam.mjs";
import * as $sizes from "../sizes.mjs";

const FILEPATH = "src/module.gleam";

export function go(data) {
  let value;
  if ($sizes.byte_size >= 0 && data.bitSize === $sizes.byte_size) {
    value = bitArraySliceToInt(data, 0, $sizes.byte_size, true, false);
  } else {
    throw makeError(
      "let_assert",
      FILEPATH,
      "my/mod",
      5,
      "go",
      "Pattern match failed, no pattern matched the value.",
      { value: data, start: 35, end: 84, pattern_start: 46, pattern_end: 77 }
    )
  }
  return value;
}
