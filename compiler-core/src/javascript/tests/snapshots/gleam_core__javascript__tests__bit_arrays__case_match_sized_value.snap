pub fn go(x) {
  case x {
    <<i:16>> -> i
    _ -> 1
  }
}


----- COMPILED JAVASCRIPT
import { bitArraySliceToInt } from "../gleam.mjs";

export function go(x) {
  if (x.bitSize === 16) {
    let i = bitArraySliceToInt(x, 0, 16, true, false);
    return i;
  } else {
    return 1;
  }
}
