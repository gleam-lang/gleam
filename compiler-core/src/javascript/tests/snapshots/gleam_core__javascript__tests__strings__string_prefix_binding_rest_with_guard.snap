----- SOURCE CODE

pub fn classify(input: String, flag: Bool) -> String {
  case input {
    "aa" <> rest if flag -> rest
    "a" <> rest -> rest
    _ -> "other"
  }
}


----- COMPILED JAVASCRIPT
export function classify(input, flag) {
  if (input.startsWith("aa") && flag) {
    let rest = input.slice(2);
    return rest;
  } else if (input.charCodeAt(0) === 97) {
    let rest = input.slice(1);
    return rest;
  } else {
    return "other";
  }
}
