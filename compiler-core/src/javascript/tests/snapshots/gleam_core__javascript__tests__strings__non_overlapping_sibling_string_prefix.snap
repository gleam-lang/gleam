----- SOURCE CODE

pub fn classify(input: String, a: Bool, b: Bool) -> String {
  case input {
    "aa" <> _ if a -> "aa"
    "a" <> _ if b -> "a-guard"
    "ac" <> _ -> "ac"
    _ -> "other"
  }
}


----- COMPILED JAVASCRIPT
export function classify(input, a, b) {
  if (input.startsWith("aa") && a) {
    return "aa";
  } else if (input.charCodeAt(0) === 97) {
    if (b) {
      return "a-guard";
    } else {
      let $ = input.slice(1);
      if ($.charCodeAt(0) === 99) {
        return "ac";
      } else {
        return "other";
      }
    }
  } else {
    return "other";
  }
}
