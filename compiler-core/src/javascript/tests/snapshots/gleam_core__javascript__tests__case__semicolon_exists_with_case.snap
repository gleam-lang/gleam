export function go() {
  let $ = [1, 2];
  let $1 = $[0];
  if ($1 === 2) {
    let b = $[1];
    b;
  } else if ($1 === 1) {
    let $2 = $[1];
    if ($2 === 3) {
      2;
    } else {
      let a = $1;
